default_platform(:ios)

KEY_FILEPATH = File.expand_path("AuthKey_P97VLS6M6Z.p8", File.dirname(__FILE__))
IOS_BUNDLE_ID = "com.penny.pennyMobile"
IOS_TEAM_ID = "H845PX7Q62"
IOS_DISTRIBUTION_IDENTITY = "Apple Distribution"
ANDROID_PACKAGE_NAME = "com.penny.penny_mobile"
ANDROID_METADATA_PATH = File.expand_path("metadata/android", File.dirname(__FILE__))

def ios_app_store_export_options(profile_name)
  {
    signingStyle: "manual",
    teamID: IOS_TEAM_ID,
    signingCertificate: IOS_DISTRIBUTION_IDENTITY,
    provisioningProfiles: {
      IOS_BUNDLE_ID => profile_name
    }
  }
end

def write_android_changelog(build_number, notes)
  return unless build_number && notes

  notes_dir = File.join(ANDROID_METADATA_PATH, "en-US", "changelogs")
  FileUtils.mkdir_p(notes_dir)
  File.write(File.join(notes_dir, "#{build_number}.txt"), notes)
end

platform :ios do

  desc "Register the app on App Store Connect"
  lane :register do
    api_key = app_store_connect_api_key(
      key_id: "P97VLS6M6Z",
      issuer_id: "09ca85e3-ffa2-4b6c-ada5-7c031ec5eb14",
      key_filepath: KEY_FILEPATH,
      in_house: false
    )

    produce(
      username: "sarathfrancis90@icloud.com",
      app_identifier: IOS_BUNDLE_ID,
      app_name: "Penny - AI Expense Tracker",
      language: "English",
      app_version: "1.0.0",
      sku: "penny-mobile-001",
      team_id: IOS_TEAM_ID,
      itc_team_id: IOS_TEAM_ID,
      skip_devcenter: true
    )
  end

  desc "Build release IPA and upload to TestFlight"
  lane :beta do |options|
    app_version  = options[:version]
    build_number = options[:build]
    notes        = options[:notes]

    api_key = app_store_connect_api_key(
      key_id: "P97VLS6M6Z",
      issuer_id: "09ca85e3-ffa2-4b6c-ada5-7c031ec5eb14",
      key_filepath: KEY_FILEPATH,
      in_house: false
    )

    # Flutter build
    Dir.chdir("..") do
      sh("flutter", "clean")
      sh("flutter", "pub", "get")
    end

    # Reinstall pods (flutter clean removes them)
    cocoapods(
      podfile: "ios/Podfile",
      clean_install: true
    )

    Dir.chdir("..") do
      build_args = ["flutter", "build", "ios", "--release", "--no-codesign"]
      if app_version && build_number
        build_args << "--build-name=#{app_version}"
        build_args << "--build-number=#{build_number}"
      end
      sh(*build_args)
    end

    # Fetch or create App Store distribution provisioning profile
    get_provisioning_profile(
      api_key: api_key,
      app_identifier: IOS_BUNDLE_ID,
      force: true,
      skip_certificate_verification: true
    )

    profile_name = lane_context[SharedValues::SIGH_NAME]

    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: IOS_TEAM_ID,
      path: "ios/Runner.xcodeproj",
      targets: ["Runner"],
      build_configurations: ["Release"],
      code_sign_identity: IOS_DISTRIBUTION_IDENTITY,
      profile_name: profile_name,
      bundle_identifier: IOS_BUNDLE_ID
    )

    # Archive and export IPA with explicit profile mapping
    build_app(
      workspace: "ios/Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      clean: true,
      export_options: ios_app_store_export_options(profile_name)
    )

    # Internal uploads intentionally skip changelog metadata so Fastlane does not
    # wait for Apple build processing before returning.
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Internal-first release: build IPA and upload to TestFlight only"
  lane :internal do |options|
    beta(version: options[:version], build: options[:build], notes: options[:notes])
  end

  desc "Repair v2.2.1: drop the stray en-US localization, set release notes on en-CA, attach build, submit for review"
  lane :repair_and_submit do |options|
    require 'spaceship'
    target_version = options[:version] || "2.2.1"
    build_number = options[:build] || "31"
    notes = options[:notes] || "You can now edit your fiscal year-end month from Settings."

    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id: "P97VLS6M6Z",
      issuer_id: "09ca85e3-ffa2-4b6c-ada5-7c031ec5eb14",
      filepath: KEY_FILEPATH
    )

    app = Spaceship::ConnectAPI::App.find(IOS_BUNDLE_ID)
    UI.message("App: #{app.name} (id: #{app.id})")

    versions = app.get_app_store_versions(filter: { versionString: target_version, platform: "IOS" })
    if versions.empty?
      edit_version = app.get_edit_app_store_version(platform: Spaceship::ConnectAPI::Platform::IOS)
      if edit_version && edit_version.version_string != target_version
        UI.user_error!("No v#{target_version} found, but editable v#{edit_version.version_string} exists. Refusing to overwrite it.")
      end

      UI.message("No v#{target_version} found; creating App Store version.")
      app.ensure_version!(target_version, platform: Spaceship::ConnectAPI::Platform::IOS)
      versions = app.get_app_store_versions(filter: { versionString: target_version, platform: "IOS" })
    end
    UI.user_error!("No v#{target_version} found after create attempt.") if versions.empty?
    version = versions.first
    UI.message("v#{version.version_string} state: #{version.app_store_state}")

    # 1. Drop any en-US localization (the broken one fastlane created)
    locs = version.get_app_store_version_localizations
    locs.each do |loc|
      UI.message("Locale: #{loc.locale}")
      if loc.locale == "en-US"
        Spaceship::ConnectAPI.delete_app_store_version_localization(app_store_version_localization_id: loc.id)
        UI.success("  → deleted en-US localization")
      end
    end

    # 2. Refetch and set release notes on en-CA
    locs = version.get_app_store_version_localizations
    en_ca = locs.find { |l| l.locale == "en-CA" }
    unless en_ca
      UI.message("en-CA localization not found; creating it.")
      version.create_app_store_version_localization(attributes: { locale: "en-CA", whatsNew: notes })
      locs = version.get_app_store_version_localizations
      en_ca = locs.find { |l| l.locale == "en-CA" }
    end
    UI.user_error!("en-CA localization not found — cannot proceed.") unless en_ca
    Spaceship::ConnectAPI.patch_app_store_version_localization(
      app_store_version_localization_id: en_ca.id,
      attributes: { whatsNew: notes }
    )
    UI.success("Set release notes on en-CA: #{notes}")

    # 3. Make sure the right build is attached
    builds = app.get_builds(filter: { "preReleaseVersion.version" => target_version, version: build_number })
    UI.user_error!("Build #{target_version}+#{build_number} not found in App Store Connect.") if builds.empty?

    build = builds.first
    Spaceship::ConnectAPI.patch_app_store_version_with_build(
      app_store_version_id: version.id,
      build_id: build.id
    )
    UI.success("Attached build #{build_number}")

    UI.success("Repair complete. Now submitting for review...")

    # 4. Submit via deliver, skipping all metadata sync (we already set what we need above)
    api_key = app_store_connect_api_key(
      key_id: "P97VLS6M6Z",
      issuer_id: "09ca85e3-ffa2-4b6c-ada5-7c031ec5eb14",
      key_filepath: KEY_FILEPATH,
      in_house: false
    )

    deliver(
      api_key: api_key,
      app_identifier: IOS_BUNDLE_ID,
      app_version: target_version,
      build_number: build_number,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: true,
      submit_for_review: true,
      automatic_release: true,
      force: true,
      run_precheck_before_submit: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false,
        export_compliance_encryption_updated: false
      }
    )
  end

  desc "Build release IPA only"
  lane :build do
    Dir.chdir("..") do
      sh("flutter", "build", "ios", "--release", "--no-codesign")
    end

    update_code_signing_settings(
      use_automatic_signing: true,
      team_id: IOS_TEAM_ID,
      path: "ios/Runner.xcodeproj"
    )

    build_app(
      workspace: "ios/Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      clean: true
    )
  end

  desc "Legacy full publish: build IPA, upload to TestFlight, then submit to App Store with auto-release"
  lane :ship do |options|
    app_version  = options[:version] || UI.user_error!("version: required (e.g. version:2.2.2)")
    build_number = options[:build]   || UI.user_error!("build: required (e.g. build:#{ENV['GITHUB_RUN_NUMBER']})")
    notes        = options[:notes]   || UI.user_error!("notes: required (release notes text)")

    api_key = app_store_connect_api_key(
      key_id: "P97VLS6M6Z",
      issuer_id: "09ca85e3-ffa2-4b6c-ada5-7c031ec5eb14",
      key_filepath: KEY_FILEPATH,
      in_house: false
    )

    # === BUILD ===
    Dir.chdir("..") do
      sh("flutter", "clean")
      sh("flutter", "pub", "get")
    end

    cocoapods(podfile: "ios/Podfile", clean_install: true)

    Dir.chdir("..") do
      sh("flutter", "build", "ios", "--release", "--no-codesign",
         "--build-name=#{app_version}",
         "--build-number=#{build_number}")
    end

    get_provisioning_profile(
      api_key: api_key,
      app_identifier: IOS_BUNDLE_ID,
      force: true,
      skip_certificate_verification: true
    )

    profile_name = lane_context[SharedValues::SIGH_NAME]

    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: IOS_TEAM_ID,
      path: "ios/Runner.xcodeproj",
      targets: ["Runner"],
      build_configurations: ["Release"],
      code_sign_identity: IOS_DISTRIBUTION_IDENTITY,
      profile_name: profile_name,
      bundle_identifier: IOS_BUNDLE_ID
    )

    build_app(
      workspace: "ios/Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      clean: true,
      export_options: ios_app_store_export_options(profile_name)
    )

    # === UPLOAD TO TESTFLIGHT (wait for processing so submit can proceed) ===
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: false,
      distribute_external: false,
      notify_external_testers: false
    )

    # === SUBMIT TO APP STORE ===
    repair_and_submit(version: app_version, build: build_number, notes: notes)
  end

  desc "Submit an already validated TestFlight build to App Store review"
  lane :promote do |options|
    app_version  = options[:version] || UI.user_error!("version: required (e.g. version:2.3.5)")
    build_number = options[:build]   || UI.user_error!("build: required")
    notes        = options[:notes]   || UI.user_error!("notes: required (release notes text)")

    repair_and_submit(version: app_version, build: build_number, notes: notes)
  end

end

platform :android do

  desc "Build release AAB and upload to Google Play internal testing"
  lane :beta do |options|
    app_version  = options[:version]
    build_number = options[:build]
    notes        = options[:notes]

    write_android_changelog(build_number, notes)

    Dir.chdir("..") do
      sh("flutter", "clean")
      sh("flutter", "pub", "get")
      build_args = ["flutter", "build", "appbundle", "--release"]
      if app_version && build_number
        build_args << "--build-name=#{app_version}"
        build_args << "--build-number=#{build_number}"
      end
      sh(*build_args)
    end

    supply(
      track: "internal",
      aab: "build/app/outputs/bundle/release/app-release.aab",
      json_key: "fastlane/play-store-key.json",
      package_name: ANDROID_PACKAGE_NAME,
      release_status: "completed",
      metadata_path: ANDROID_METADATA_PATH,
      skip_upload_metadata: true,
      skip_upload_changelogs: build_number.nil? || notes.nil?,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end

  desc "Internal-first release: build AAB and upload to Play internal testing"
  lane :internal do |options|
    beta(version: options[:version], build: options[:build], notes: options[:notes])
  end

  desc "Deprecated alias: build AAB and upload to Play internal testing"
  lane :ship do |options|
    app_version  = options[:version] || UI.user_error!("version: required (e.g. version:2.2.2)")
    build_number = options[:build]   || UI.user_error!("build: required (e.g. build:#{ENV['GITHUB_RUN_NUMBER']})")
    notes        = options[:notes]   || UI.user_error!("notes: required (release notes text)")

    # Write release notes to the locale path supply expects (en-US is Play Store default)
    write_android_changelog(build_number, notes)

    # Build AAB with explicit version + build number
    Dir.chdir("..") do
      sh("flutter", "clean")
      sh("flutter", "pub", "get")
      sh("flutter", "build", "appbundle", "--release",
         "--build-name=#{app_version}",
         "--build-number=#{build_number}")
    end

    # Deprecated alias kept for local compatibility. CI uses android internal
    # for Play internal testing and android promote for production promotion.
    supply(
      track: "internal",
      aab: "build/app/outputs/bundle/release/app-release.aab",
      json_key: "fastlane/play-store-key.json",
      package_name: ANDROID_PACKAGE_NAME,
      release_status: "completed",
      metadata_path: ANDROID_METADATA_PATH,
      skip_upload_metadata: true,
      skip_upload_changelogs: false,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end

  desc "Promote the validated Play internal release to production"
  lane :promote do |options|
    build_number = options[:build] || UI.user_error!("build: required")
    notes        = options[:notes]

    write_android_changelog(build_number, notes)

    supply(
      track: "internal",
      track_promote_to: "production",
      json_key: "fastlane/play-store-key.json",
      package_name: ANDROID_PACKAGE_NAME,
      release_status: "completed",
      rollout: "1.0",
      metadata_path: ANDROID_METADATA_PATH,
      skip_upload_metadata: true,
      skip_upload_changelogs: notes.nil?,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end

  desc "Upload metadata, screenshots, and images only (no build)"
  lane :metadata do
    supply(
      json_key: "fastlane/play-store-key.json",
      package_name: ANDROID_PACKAGE_NAME,
      skip_upload_apk: true,
      skip_upload_aab: true
    )
  end

  desc "Build release AAB only (no upload)"
  lane :build do
    Dir.chdir("..") do
      sh("flutter", "clean")
      sh("flutter", "pub", "get")
      sh("flutter", "build", "appbundle", "--release")
    end
  end

end
