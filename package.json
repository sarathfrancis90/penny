{
  "name": "penny",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --max-warnings=0",
    "test": "vitest run",
    "test:db": "npx firebase-tools@15.19.1 emulators:exec --project penny-ci --only firestore,storage \"vitest run --config vitest.database.config.ts\"",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "ci:policy": "tsx scripts/ci/policy-guard.ts",
    "lint:ci": "eslint apps packages scripts --max-warnings=0",
    "api:dev": "tsx watch apps/api/src/server.ts",
    "api:typecheck": "tsc -p tsconfig.api.json --noEmit",
    "api:build": "tsup apps/api/src/server.ts --format cjs --platform node --target node22 --sourcemap --out-dir dist/api",
    "api:start": "node dist/api/server.js",
    "api:test": "vitest run apps/api packages/shared",
    "api:check": "npm run api:typecheck && npm run api:test && npm run api:build",
    "api:contract:generate": "tsx scripts/api/generate-openapi.ts",
    "api:contract": "tsx scripts/api/generate-openapi.ts --check",
    "api:parity": "tsx scripts/api/compare-old-new.ts",
    "api:smoke": "tsx scripts/api/smoke-api.ts",
    "mobile:api-only:check": "tsx scripts/mobile/check-api-only.ts",
    "docs:agents:generate": "tsx scripts/agents/generate-agent-docs.ts",
    "docs:agents:check": "tsx scripts/agents/generate-agent-docs.ts --check",
    "docs:agents:lint": "tsx scripts/agents/lint-agent-docs.ts",
    "docs:agents:test": "vitest run scripts/agents apps/api/src/routes/__tests__/route-surface.test.ts",
    "docs:auto": "tsx scripts/agents/auto-update-agent-docs.ts",
    "generate-secret": "node scripts/generate-jwt-secret.js"
  },
