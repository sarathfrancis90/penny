#!/bin/bash
# Pre-push hook: runs Flutter unit tests before allowing push.
#
# - Unit tests are STRICT (block push on failure). They're fast and stable.
# - Integration tests are NOT run here — they belong in the GitHub Actions
#   workflow (.github/workflows/mobile-tests.yml) and on-demand locally.
#   Reason: integration tests are slow + simulator-dependent, and previously
#   their output was being silently swallowed by `... | tail -1`, masking
#   broken tests. CI is a more reliable place for them.
#
# Bypass (use sparingly): git push --no-verify

set -euo pipefail

echo "🧪 Running pre-push unit tests..."
cd mobile
flutter test test/ --reporter compact
echo "✅ Unit tests passed"
