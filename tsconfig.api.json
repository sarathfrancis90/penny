{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "jsx": "react-jsx",
    "noEmit": true,
    "allowJs": false,
    "isolatedModules": false,
    "incremental": false
  },
  "include": [
    "apps/api/**/*.ts",
    "packages/shared/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "dist"
  ]
}
